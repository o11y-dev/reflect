      {
        "type": "command",
        "bash": "/usr/local/bin/otel-hook",
        "timeoutSec": 30
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "/usr/local/bin/otel-hook",
        "timeoutSec": 30
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "/usr/local/bin/otel-hook",
        "timeoutSec": 30
      }
    ],
    "errorOccurred": [
